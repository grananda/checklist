{
  "name": "checklist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lista de tareas compartida en tiempo real (piloto AIDD).",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @checklist/shared build && pnpm --filter @checklist/server build && pnpm --filter @checklist/client build",
    "build:shared": "pnpm --filter @checklist/shared build",
    "dev:server": "pnpm --filter @checklist/server dev",
    "dev:client": "pnpm --filter @checklist/client dev",
    "start": "pnpm --filter @checklist/server start",
    "test": "pnpm --filter @checklist/shared build && pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
