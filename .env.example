# Configuración del servidor CheckList. Copia este fichero a `.env` y ajusta los valores.

# Puerto HTTP del servidor.
PORT=3000

# Ruta del fichero SQLite (persistencia). En Docker se monta sobre un volumen.
DATABASE_URL=./data/checklist.db

# Origen permitido para CORS. Con contenedor único de mismo origen puede dejarse en el propio host.
CORS_ORIGIN=http://localhost:3000

# Límites de dominio (NFR-12). Validados en servidor.
MAX_TAREAS=100
MAX_TITULO_LEN=120
MAX_DESC_LEN=2000

# Entorno de ejecución: development | production | test
NODE_ENV=development
